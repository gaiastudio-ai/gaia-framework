{
  "_schema_version": "1.0.0",
  "_description": "GAIA deterministic-tools readiness registry. Single source of truth for /gaia-doctor preflight scan. Each entry declares: probe command (presence), version command (resolution), applies_to_stacks (filter), tier (0/1/2 for scan-fidelity verdict), and per-OS install commands.",
  "_tiers": {
    "0": "LLM-only — always achievable; requires only core POSIX + jq/yq/python3.",
    "1": "Pure pip / npm / static-binary — cheap to install on any host; no native toolchain.",
    "2": "Heavy native or containerized — Homebrew, Docker, or per-language SDK required."
  },
  "tools": {
    "bash": {
      "name": "bash",
      "category": "core",
      "description": "GNU Bash >= 4.0 (orchestrator + globstar walk)",
      "tier": 0,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v bash",
      "version_cmd": "bash -c 'echo ${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}'",
      "min_version": "4.0",
      "environment_warning": "macOS ships bash 3.2 by default; orchestrator globstar walks require 4.0+",
      "install": {
        "macos": "brew install bash",
        "linux": "# bash >= 4.0 is standard on Linux; install via apt-get install bash if missing",
        "docker": null
      },
      "notes": "Environment warning row (⚠) when version < 4.0; otherwise core present."
    },
    "jq": {
      "name": "jq",
      "category": "core",
      "description": "JSON processor (every adapter + envelope writer depends on it)",
      "tier": 0,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v jq",
      "version_cmd": "jq --version",
      "min_version": null,
      "install": {
        "macos": "brew install jq",
        "linux": "apt-get install -y jq || yum install -y jq",
        "docker": null
      },
      "notes": "Core dependency — every skill that emits JSON envelopes requires it."
    },
    "yq": {
      "name": "yq",
      "category": "core",
      "description": "YAML processor (project-config + sprint-status reads)",
      "tier": 0,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v yq",
      "version_cmd": "yq --version",
      "min_version": null,
      "install": {
        "macos": "brew install yq",
        "linux": "curl -sSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -o /usr/local/bin/yq && chmod +x /usr/local/bin/yq",
        "docker": null
      },
      "notes": "Core dependency — config-yaml-editor + sprint-state.sh both require it."
    },
    "python3": {
      "name": "python3",
      "category": "core",
      "description": "Python 3 runtime (detect-signals + config merge + yaml conversion)",
      "tier": 0,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v python3",
      "version_cmd": "python3 --version",
      "min_version": "3.8",
      "install": {
        "macos": "brew install python3",
        "linux": "apt-get install -y python3 python3-pip",
        "docker": null
      },
      "notes": "detect-signals.sh requires PyYAML for --merge-into mode."
    },
    "git": {
      "name": "git",
      "category": "core",
      "description": "Git VCS (story-state writes + branch hygiene)",
      "tier": 0,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v git",
      "version_cmd": "git --version",
      "min_version": "2.20",
      "install": {
        "macos": "brew install git",
        "linux": "apt-get install -y git",
        "docker": null
      },
      "notes": "Required for /gaia-dev-story branch + push steps; degrades gracefully in non-git CWD."
    },
    "vulture": {
      "name": "vulture",
      "category": "dead-code",
      "description": "Python dead-code finder",
      "tier": 1,
      "applies_to_stacks": ["python"],
      "probe_cmd": "command -v vulture",
      "version_cmd": "vulture --version",
      "min_version": null,
      "install": {
        "macos": "pip install vulture",
        "linux": "pip install vulture",
        "docker": "docker run --rm -v $PWD:/src python:3.11-slim sh -c 'pip install vulture && vulture /src'"
      },
      "notes": "Tier 1 — pure pip install; covers F-10 Python dead-code gap."
    },
    "pip-audit": {
      "name": "pip-audit",
      "category": "cve-scan",
      "description": "Python dependency CVE audit (PyPI advisory DB)",
      "tier": 1,
      "applies_to_stacks": ["python"],
      "probe_cmd": "command -v pip-audit",
      "version_cmd": "pip-audit --version",
      "min_version": null,
      "install": {
        "macos": "pip install pip-audit",
        "linux": "pip install pip-audit",
        "docker": null
      },
      "notes": "Tier 1 alternative to grype for Python repos; no native toolchain required."
    },
    "cyclonedx-bom": {
      "name": "cyclonedx-bom",
      "category": "sbom",
      "description": "Python SBOM generator (CycloneDX format)",
      "tier": 1,
      "applies_to_stacks": ["python"],
      "probe_cmd": "command -v cyclonedx-py",
      "version_cmd": "cyclonedx-py --version",
      "min_version": null,
      "install": {
        "macos": "pip install cyclonedx-bom",
        "linux": "pip install cyclonedx-bom",
        "docker": null
      },
      "notes": "Tier 1 SBOM for Python; alternative to cdxgen + syft."
    },
    "osv-scanner": {
      "name": "osv-scanner",
      "category": "cve-scan",
      "description": "Google OSV.dev CVE scanner (single static binary, any stack)",
      "tier": 1,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v osv-scanner",
      "version_cmd": "osv-scanner --version",
      "min_version": null,
      "install": {
        "macos": "brew install osv-scanner",
        "linux": "go install github.com/google/osv-scanner/cmd/osv-scanner@latest",
        "docker": "docker pull ghcr.io/google/osv-scanner:latest"
      },
      "notes": "Tier 1 cross-stack CVE scanner — single static binary, no native toolchain."
    },
    "cdxgen": {
      "name": "cdxgen",
      "category": "sbom",
      "description": "CycloneDX SBOM generator (multi-stack via Node)",
      "tier": 1,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v cdxgen",
      "version_cmd": "cdxgen --version",
      "min_version": null,
      "install": {
        "macos": "npm i -g @cyclonedx/cdxgen",
        "linux": "npm i -g @cyclonedx/cdxgen",
        "docker": "docker pull ghcr.io/cyclonedx/cdxgen:latest"
      },
      "notes": "Tier 1 SBOM — requires Node but otherwise no native deps."
    },
    "yamllint": {
      "name": "yamllint",
      "category": "linter",
      "description": "YAML linter (CI workflow + project-config validation)",
      "tier": 1,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v yamllint",
      "version_cmd": "yamllint --version",
      "min_version": null,
      "install": {
        "macos": "pip install yamllint",
        "linux": "pip install yamllint",
        "docker": null
      },
      "notes": "Tier 1 — yamllint adapter ships under adapters/yamllint/."
    },
    "grype": {
      "name": "grype",
      "category": "cve-scan",
      "description": "Container/dep vulnerability scan via Grype DB",
      "tier": 2,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v grype",
      "version_cmd": "grype version --output json | jq -r .application",
      "min_version": null,
      "install": {
        "macos": "brew install grype",
        "linux": "curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b /usr/local/bin",
        "docker": "docker pull anchore/grype:latest"
      },
      "notes": "Bundles its own vulnerability DB; ADR-122 / E70-S9 enforce DB-age + checksum trust boundary."
    },
    "syft": {
      "name": "syft",
      "category": "sbom",
      "description": "Anchore Syft SBOM generator (any stack, native binary)",
      "tier": 2,
      "applies_to_stacks": ["any"],
      "probe_cmd": "command -v syft",
      "version_cmd": "syft version --output json | jq -r .version",
      "min_version": null,
      "install": {
        "macos": "brew install syft",
        "linux": "curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b /usr/local/bin",
        "docker": "docker pull anchore/syft:latest"
      },
      "notes": "Tier 2 cross-stack SBOM; pairs with grype for the CVE+SBOM pipeline."
    },
    "spotbugs": {
      "name": "spotbugs",
      "category": "dead-code",
      "description": "JVM static analysis + dead-code detector",
      "tier": 2,
      "applies_to_stacks": ["java", "android", "kotlin"],
      "probe_cmd": "command -v spotbugs",
      "version_cmd": "spotbugs -version 2>&1",
      "min_version": null,
      "install": {
        "macos": "brew install spotbugs",
        "linux": "# Download from https://spotbugs.github.io/ or via SDKMAN: sdk install spotbugs",
        "docker": "docker pull spotbugs/spotbugs:latest"
      },
      "notes": "Tier 2 — JVM-only; not-applicable rows for pure-Python or JS stacks."
    },
    "detekt": {
      "name": "detekt",
      "category": "linter",
      "description": "Static analysis for Kotlin (Android source)",
      "tier": 2,
      "applies_to_stacks": ["kotlin", "android"],
      "probe_cmd": "command -v detekt",
      "version_cmd": "detekt --version",
      "min_version": "1.23.0",
      "install": {
        "macos": "brew install detekt",
        "linux": "curl -sSLO https://github.com/detekt/detekt/releases/download/v1.23.5/detekt-cli-1.23.5.zip && unzip detekt-cli-*.zip -d /usr/local/share && ln -sf /usr/local/share/detekt-cli-*/bin/detekt-cli /usr/local/bin/detekt",
        "docker": null
      },
      "notes": "Tier 2 — Android/Kotlin only; ships as adapters/detekt/."
    },
    "ktlint": {
      "name": "ktlint",
      "category": "linter",
      "description": "Kotlin style linter (Android source)",
      "tier": 2,
      "applies_to_stacks": ["kotlin", "android"],
      "probe_cmd": "command -v ktlint",
      "version_cmd": "ktlint --version",
      "min_version": null,
      "install": {
        "macos": "brew install ktlint",
        "linux": "curl -sSLO https://github.com/pinterest/ktlint/releases/latest/download/ktlint && chmod +x ktlint && mv ktlint /usr/local/bin/",
        "docker": null
      },
      "notes": "Tier 2 — Android/Kotlin only; ships as adapters/ktlint/."
    },
    "mobsf": {
      "name": "mobsf",
      "category": "mobile-sast",
      "description": "Mobile Security Framework — Android/iOS static analysis",
      "tier": 2,
      "applies_to_stacks": ["android", "ios"],
      "probe_cmd": "command -v mobsf || command -v mobsfscan",
      "version_cmd": "mobsfscan --version 2>&1 || echo 'unknown'",
      "min_version": null,
      "install": {
        "macos": "pip install mobsfscan",
        "linux": "pip install mobsfscan",
        "docker": "docker pull opensecurity/mobile-security-framework-mobsf:latest"
      },
      "notes": "Tier 2 — mobile-only (Android + iOS); ships as adapters/mobsf/."
    }
  }
}
